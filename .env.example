# 市场情报分析系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# Tushare Pro Token (A股数据)
# 获取地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# Binance API (数字货币)
# 获取地址: https://www.binance.com/en/support/faq/how-to-create-api-keys-360002502072
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# FRED API (美国国债数据)
# 获取地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# 可选: Telegram Bot Token (用于推送预警)
# 获取地址: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
